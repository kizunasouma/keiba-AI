# データベース設定
DATABASE_URL=postgresql://keiba_user:keiba_pass@localhost:5432/keiba_db

# JV-Link設定
# JRA-VANに登録して取得した17桁の利用キー
JVLINK_SERVICE_KEY=your_17_digit_service_key_here

# JV-Linkのソフトウェアid（JRA-VANに登録したもの。未登録なら"UNKNOWN"）
JVLINK_SOFTWARE_ID=UNKNOWN

# JV-Linkのデータ保存パス（空白の場合はJV-Linkのデフォルトパスを使用）
JVLINK_SAVE_PATH=
