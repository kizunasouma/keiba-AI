# ===== データベース設定 =====
POSTGRES_USER=keiba_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=keiba_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ===== pgAdmin設定 =====
PGADMIN_EMAIL=admin@keiba.local
PGADMIN_PASSWORD=your_pgadmin_password

# ===== JV-Link設定 =====
# JRA-VANに登録して取得した17桁の利用キー（ハイフン付き）
JVLINK_SERVICE_KEY=XXXX-XXXX-XXXX-XXXX-X

# JV-LinkのソフトウェアID（JRA-VANに登録したもの。未登録なら空欄）
JVLINK_SOFTWARE_ID=

# JV-Linkのデータ保存パス（空欄の場合はJV-Linkのデフォルトパスを使用）
JVLINK_SAVE_PATH=
